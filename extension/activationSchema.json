{
  "types": {
    "intersight_endpoint": {
      "type": "object",
      "displayName": "Intersight Endpoint",
      "summaryPattern": "{url}",
      "properties": {
        "url": {
          "displayName": "Intersight URL",
          "type": "text",
          "nullable": false,
          "default": "",
          "constraints": [
            {
              "type": "NOT_EMPTY"
            },
            {
              "type": "PATTERN",
              "pattern": "^https?://[^/\\s]+$",
              "customMessage": "Must be a valid URL without a trailing slash, e.g. https://eu-central-1.intersight.com"
            }
          ],
          "metadata": {
            "placeholder": "https://eu-central-1.intersight.com"
          }
        },
        "client_id": {
          "displayName": "OAuth2 Client ID",
          "type": "secret",
          "nullable": false,
          "default": "",
          "constraints": [
            {
              "type": "NOT_EMPTY"
            }
          ]
        },
        "client_secret": {
          "displayName": "OAuth2 Client Secret",
          "type": "secret",
          "nullable": false,
          "default": "",
          "constraints": [
            {
              "type": "NOT_EMPTY"
            }
          ]
        },
        "verify_tls": {
          "displayName": "Verify TLS Certificate",
          "type": "boolean",
          "nullable": false,
          "default": true,
          "description": "Recommended: enabled. Disable only for self-signed appliance certificates."
        },
        "proxy": {
          "displayName": "Proxy URL (optional)",
          "description": "Optional HTTP/HTTPS proxy in the form http(s)://host:port (port 1-65535). Leave empty for direct connection.",
          "type": "text",
          "nullable": true,
          "constraints": [
            {
              "type": "PATTERN",
              "pattern": "^$|^https?://[^/\\s:]+:([1-9][0-9]{0,3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5])$",
              "customMessage": "Proxy must be empty or in format http(s)://host:port (port 1-65535). Example: http://proxy.example.com:8080"
            }
          ],
          "metadata": {
            "placeholder": "http://proxy.example.com:8080"
          }
        },
        "poll_interval": {
          "displayName": "Poll Interval (minutes)",
          "type": "integer",
          "nullable": false,
          "default": 5,
          "constraints": [
            {
              "type": "RANGE",
              "minimum": 1,
              "maximum": 60
            }
          ]
        },
        "enable_alarms": {
          "displayName": "Enable Alarm Monitoring",
          "type": "boolean",
          "nullable": false,
          "default": true,
          "description": "At least one severity below must be enabled"
        },
        "enable_critical": {
          "displayName": "Enabled Severities - Critical",
          "type": "boolean",
          "nullable": false,
          "default": true,
          "precondition": {
            "type": "EQUALS",
            "property": "enable_alarms",
            "expectedValue": true
          }
        },
        "enable_warning": {
          "displayName": "Enabled Severities - Warning",
          "type": "boolean",
          "nullable": false,
          "default": true,
          "precondition": {
            "type": "EQUALS",
            "property": "enable_alarms",
            "expectedValue": true
          }
        },
        "enable_info": {
          "displayName": "Enabled Severities - Info",
          "type": "boolean",
          "nullable": false,
          "default": false,
          "precondition": {
            "type": "EQUALS",
            "property": "enable_alarms",
            "expectedValue": true
          }
        },
        "advisories_enabled": {
          "displayName": "Enable Security Advisories",
          "type": "boolean",
          "nullable": false,
          "default": false,
          "description": "At least one advisory type below must be enabled. PSIRT = Cisco Security Advisories, FN = Field Notices, EOL = End-of-Life notices."
        },
        "advisories_poll_hours": {
          "displayName": "Advisory Poll Interval (hours)",
          "type": "integer",
          "nullable": false,
          "default": 24,
          "constraints": [
            {
              "type": "RANGE",
              "minimum": 1,
              "maximum": 168
            }
          ],
          "precondition": {
            "type": "EQUALS",
            "property": "advisories_enabled",
            "expectedValue": true
          },
          "description": "Recommended: 24h. Davis problems are kept open via 5h keepalive."
        },
        "advisories_include_psirt": {
          "displayName": "Include PSIRT Advisories",
          "type": "boolean",
          "nullable": false,
          "default": true,
          "precondition": {
            "type": "EQUALS",
            "property": "advisories_enabled",
            "expectedValue": true
          }
        },
        "advisories_include_fn": {
          "displayName": "Include Field Notices",
          "type": "boolean",
          "nullable": false,
          "default": true,
          "precondition": {
            "type": "EQUALS",
            "property": "advisories_enabled",
            "expectedValue": true
          }
        },
        "advisories_include_eol": {
          "displayName": "Include End-of-Life Notices",
          "type": "boolean",
          "nullable": false,
          "default": true,
          "precondition": {
            "type": "EQUALS",
            "property": "advisories_enabled",
            "expectedValue": true
          }
        }
      }
    },
    "pythonRemote": {
      "type": "object",
      "displayName": "Cisco Intersight Remote Configuration",
      "properties": {
        "endpoints": {
          "displayName": "Intersight Endpoints",
          "type": "list",
          "items": {
            "type": {
              "$ref": "#/types/intersight_endpoint"
            }
          },
          "nullable": false,
          "minItems": 1
        }
      }
    },
    "pythonLocal": {
      "type": "object",
      "displayName": "Cisco Intersight Local Configuration",
      "properties": {
        "endpoints": {
          "displayName": "Intersight Endpoints",
          "type": "list",
          "items": {
            "type": {
              "$ref": "#/types/intersight_endpoint"
            }
          },
          "nullable": false,
          "minItems": 1
        }
      }
    }
  },
  "properties": {
    "endpoints": {
      "displayName": "Intersight Endpoints",
      "type": "list",
      "items": {
        "type": {
          "$ref": "#/types/intersight_endpoint"
        }
      },
      "nullable": false,
      "minItems": 1
    }
  },
  "required": [
    "endpoints"
  ]
}
